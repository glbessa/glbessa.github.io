---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostDetailLayout from '../../components/PostDetailLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => {
    const slug = post.id.replace(/\.(md|mdx)$/, '');
    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.hero}
  url={`/posts/${slug}`}
  type="article"
>
  <section class="bg-bg px-6 pb-24 pt-32 text-text">
    <PostDetailLayout data={{ ...post.data, slug }} type="posts">
      <Content />
    </PostDetailLayout>
  </section>
</BaseLayout>
