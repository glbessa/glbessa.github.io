---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const postModules = import.meta.glob('./_*.jsx');
  const entries = await Promise.all(
    Object.entries(postModules).map(async ([path, importer]) => {
      const mod = await importer();
      const slug = mod.metadata?.slug ?? path.split('/').pop().replace(/^_/, '').replace('.jsx', '');
      return {
        params: { slug },
        props: { slug, metadata: mod.metadata },
      };
    })
  );

  return entries;
}

const { slug, metadata } = Astro.props;
const postModules = import.meta.glob('./_*.jsx');
const PostPage = (await postModules[`./_${slug}.jsx`]()).default;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  image={metadata.hero}
  url={`/posts/${slug}`}
  type="article"
>
  <section class="bg-slate-50 px-6 pb-24 pt-32 text-slate-900">
    <PostPage />
  </section>
</BaseLayout>
