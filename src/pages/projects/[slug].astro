---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostDetailLayout from '../../components/PostDetailLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => {
    const slug = project.id.replace(/\.(md|mdx)$/, '');
    return {
      params: { slug },
      props: { project, slug },
    };
  });
}

const { project, slug } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={project.data.hero}
  url={`/projects/${slug}`}
  type="article"
>
  <section class="bg-bg px-6 pb-24 pt-32 text-text">
    <PostDetailLayout data={{ ...project.data, slug }} type="projects">
      <Content />
    </PostDetailLayout>
  </section>
</BaseLayout>
