---
import BaseLayout from '../layouts/BaseLayout.astro';
import Projects from './_Projects.jsx';
import { getData } from '../data';
import { getCollection } from 'astro:content';

const data = getData();
const seo = data.site.pages.projects;

const projectsCollection = await getCollection('projects');
const projects = projectsCollection.map(project => ({
  slug: project.id.replace(/\.(md|mdx)$/, ''),
  ...project.data,
}));
---

<BaseLayout title={seo.title} description={seo.description} url="/projects">
  <section class="bg-slate-50 px-6 pb-24 pt-32 text-slate-900">
    <div class="container mx-auto">
      <Projects client:load projects={projects} />
    </div>
  </section>
</BaseLayout>
